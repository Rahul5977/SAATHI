# LLM Backend: "openai" or "local"
LLM_BACKEND=openai

# OpenAI (used when LLM_BACKEND=openai)
OPENAI_API_KEY=sk-your-key-here

# Local LLM (used when LLM_BACKEND=local)
LOCAL_LLM_BASE_URL=http://localhost:8001/v1
LOCAL_LLM_MODEL=saathi-7b

# Embeddings: "openai" or "local"
EMBEDDING_BACKEND=openai
LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Redis
REDIS_URL=redis://localhost:6379

# Data
DATASET_DIR=dataset
